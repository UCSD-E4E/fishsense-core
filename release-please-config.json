{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "fishsense",
      "components": ["fishsense-core", "fishsense_core"],
      "merge": false
    }
  ],
  "packages": {
    "rust/fishsense-core": {
      "release-type": "rust",
      "package-name": "fishsense-core",
      "extra-files": [
        {
          "type": "generic",
          "path": "/README.md"
        }
      ]
    },
    "python/fishsense_core": {
      "release-type": "rust",
      "package-name": "fishsense_core",
      "extra-files": [
        {
          "type": "generic",
          "path": "/README.md"
        }
      ]
    }
  }
}
