{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "linked-versions": true,
  "packages": {
    ".": {
      "release-type": "simple",
      "skip-github-release": true,
      "extra-files": [
        {
          "type": "generic",
          "path": "README.md"
        }
      ]
    },
    "rust/fishsense-core": {
      "release-type": "rust",
      "package-name": "fishsense-core"
    },
    "python/fishsense_core": {
      "release-type": "rust",
      "package-name": "fishsense_core"
    }
  }
}
