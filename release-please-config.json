{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "fishsense",
      "components": ["fishsense-meta", "fishsense-core", "fishsense_core"],
      "merge": false
    }
  ],
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "fishsense-meta",
      "skip-github-release": true,
      "extra-files": [
        {
          "type": "generic",
          "path": "README.md"
        }
      ]
    },
    "rust/fishsense-core": {
      "release-type": "rust",
      "package-name": "fishsense-core"
    },
    "python/fishsense_core": {
      "release-type": "rust",
      "package-name": "fishsense_core"
    }
  }
}
